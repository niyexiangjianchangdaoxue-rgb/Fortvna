# Fortvna secrets 模板 —— 只含变量名与假值, 入库 (第 5.4 条)
# 真实值放于仓库目录之外的 ~/.fortvna/secrets.env (chmod 600, D-011)
# 新增配置项必须同步到本文件, 否则 CI 失败 (第 5.3 条)

# Cosmos 通道 (Key-C: 读/交易/划转允许, 提币禁止)
OKX_C_API_KEY=your_cosmos_api_key
OKX_C_SECRET=your_cosmos_secret
OKX_C_PASSPHRASE=your_cosmos_passphrase

# Minisha 通道 (Key-M: 读/交易允许, 划转/提币禁止)
OKX_M_API_KEY=your_minisha_api_key
OKX_M_SECRET=your_minisha_secret
OKX_M_PASSPHRASE=your_minisha_passphrase

# 基础设施
POSTGRES_PASSWORD=your_postgres_password
REDIS_PASSWORD=your_redis_password

# 本地代理 (第 4.4 条, 敏感物)
FORTVNA_PROXY=http://127.0.0.1:1082

# 划转限额 (第 11 章)
TRANSFER_MAX_SINGLE_USDT=100
TRANSFER_MAX_DAILY_USDT=500
